// Prisma schema for Polso - Financial Management Platform
// Database: Neon PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Multi-tenant Organization
// ============================================

model Organization {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("client") // "partner" | "client"
  currency        String   @default("EUR")
  timezone        String   @default("Europe/Madrid")
  fiscalYearStart Int      @default(1) @map("fiscal_year_start")
  dateFormat      String   @default("MM/dd/yyyy") @map("date_format")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Subscription
  planType        String    @default("starter") @map("plan_type")
  planInterval    String?   @map("plan_interval") // "monthly" | "annual"
  planStartedAt   DateTime? @map("plan_started_at")
  planExpiresAt   DateTime? @map("plan_expires_at")
  trialEndsAt     DateTime? @map("trial_ends_at")

  // Creem billing
  creemCustomerId     String? @map("creem_customer_id")
  creemSubscriptionId String? @map("creem_subscription_id")

  // Agent channels
  whatsappPhone  String? @unique @map("whatsapp_phone")
  telegramChatId String? @unique @map("telegram_chat_id")
  agentOptOut    Boolean @default(false) @map("agent_opt_out")

  // Onboarding
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")

  // Export preferences
  csvSeparator       String? @default(";") @map("csv_separator")
  defaultExportRange String  @default("month") @map("default_export_range") // "month" | "quarter" | "year"

  // Partner profile
  logoFilePath   String? @map("logo_file_path")
  taxId          String? @map("tax_id")
  address        String?
  contactEmail   String? @map("contact_email")

  // Partner reminder settings
  reminderCooldownHours  Int     @default(24) @map("reminder_cooldown_hours")
  receiptReminderHours   Int     @default(48) @map("receipt_reminder_hours")
  autoRemindersEnabled   Boolean @default(true) @map("auto_reminders_enabled")

  // Partner invitation settings
  invitationExpiryDays Int @default(7) @map("invitation_expiry_days")

  // Partner notification settings
  digestCadence           String  @default("daily") @map("digest_cadence") // "none" | "daily" | "weekly"
  notifyOnClientConnected Boolean @default(true) @map("notify_on_client_connected")

  // Scheduled plan changes (for downgrades)
  scheduledPlanType     String?   @map("scheduled_plan_type")
  scheduledPlanInterval String?   @map("scheduled_plan_interval")
  scheduledChangeAt     DateTime? @map("scheduled_change_at")

  // Relations
  userOrganizations    UserOrganization[]
  accounts             Account[]
  pendingRequisitions  PendingRequisition[]
  transactions         Transaction[]
  entries              Entry[]
  counterparties       Counterparty[]
  categories           Category[]
  transactionDocuments TransactionDocument[]
  recurringPatterns    RecurringPattern[]
  dismissedPatterns    DismissedPattern[]
  alerts               Alert[]
  exports              Export[]
  invitations          Invitation[]
  categoryPreferences  CategoryPreference[]
  inboxItems           InboxItem[]
  matchSuggestions     MatchSuggestion[]
  agentLinkCodes       AgentLinkCode[]
  proactiveMessages    ProactiveMessage[]

  // Partner ↔ Client links
  partnerLinks PartnerClient[] @relation("AsClient")
  clientLinks  PartnerClient[] @relation("AsPartner")

  @@map("organizations")
}

model UserOrganization {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           String   @default("member")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@map("user_organizations")
}

// ============================================
// Banking - Connected Bank Accounts
// ============================================

model Account {
  id                   String    @id @default(cuid())
  organizationId       String    @map("organization_id")
  requisitionId        String?   @map("requisition_id")
  institutionId        String?   @map("institution_id")
  requisitionExpiresAt DateTime? @map("requisition_expires_at")
  externalAccountId    String?   @map("external_account_id")
  iban                 String?
  bic                  String?
  name                 String
  mask                 String?
  officialName         String?   @map("official_name")
  accountType          String?   @map("account_type")
  accountSubtype       String?   @map("account_subtype")
  currency             String    @default("EUR")
  institutionName      String?   @map("institution_name")
  institutionLogo      String?   @map("institution_logo")
  status               String    @default("pending")
  lastSyncedAt         DateTime? @map("last_synced_at")
  syncError            String?   @map("sync_error")
  syncErrorRetries     Int       @default(0) @map("sync_error_retries")
  balanceAvailable     Float?    @map("balance_available")
  balanceCurrent       Float?    @map("balance_current")
  balanceLimit         Float?    @map("balance_limit")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  alerts       Alert[]

  @@index([organizationId])
  @@index([status])
  @@index([requisitionId])
  @@map("accounts")
}

model PendingRequisition {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  requisitionId  String   @map("requisition_id")
  institutionId  String   @map("institution_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("pending_requisitions")
}

// ============================================
// Transactions - Raw bank transactions
// ============================================

model Transaction {
  id                    String    @id @default(cuid())
  organizationId        String    @map("organization_id")
  accountId             String    @map("account_id")
  externalTransactionId String?   @map("external_transaction_id")
  amount                Float
  currency              String    @default("EUR")
  date                  DateTime
  authorizedDate        DateTime? @map("authorized_date")
  name                  String?
  merchantName          String?   @map("merchant_name")
  pending               Boolean   @default(false)
  paymentChannel        String?   @map("payment_channel")
  transactionType       String?   @map("transaction_type") // debit, credit
  category              String?
  categoryDetailed      String?   @map("category_detailed")
  counterpartyName      String?   @map("counterparty_name")
  createdAt             DateTime  @default(now()) @map("created_at")

  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account                Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  entry                  Entry?
  inboxItems             InboxItem[]
  matchSuggestions       MatchSuggestion[]
  transactionAttachments TransactionAttachment[]
  documents              TransactionDocument[]

  @@unique([accountId, externalTransactionId])
  @@unique([organizationId, externalTransactionId])
  @@index([organizationId])
  @@index([accountId])
  @@index([date])
  @@index([counterpartyName])
  @@map("transactions")
}

// ============================================
// Entries - Unified enrichment layer (replaces Expense + Income)
// ============================================

model Entry {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  transactionId  String? @unique @map("transaction_id") // null = manual entry

  direction String // "expense" | "income"

  amount      Float
  currency    String   @default("EUR")
  date        DateTime
  description String?

  // Enrichment
  categoryId         String?  @map("category_id")
  counterpartyId     String?  @map("counterparty_id")
  entryType          String   @default("variable") @map("entry_type") // fixed | variable
  recurringPatternId String?  @map("recurring_pattern_id")

  // Status
  status String @default("pending") // pending | verified | excluded

  // Flags
  isManual    Boolean @default(false) @map("is_manual")
  isRecurring Boolean @default(false) @map("is_recurring")

  notes String?

  // Tax (IVA / VAT)
  taxAmount Float? @map("tax_amount")
  taxRate   Float? @map("tax_rate") // e.g. 0.21, 0.10, 0.04

  // Categorization metadata
  categorySource     String? @map("category_source") // vendor, gocardless, keyword, manual
  categoryConfidence Float?  @map("category_confidence")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction      Transaction?      @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  category         Category?         @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  counterparty     Counterparty?     @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  recurringPattern RecurringPattern? @relation(fields: [recurringPatternId], references: [id], onDelete: SetNull)
  alerts           Alert[]

  @@index([organizationId])
  @@index([date])
  @@index([direction])
  @@index([status])
  @@index([entryType])
  @@index([categoryId])
  @@index([counterpartyId])
  @@map("entries")
}

// ============================================
// Counterparties - Unified vendors + clients
// ============================================

model Counterparty {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")

  name           String
  normalizedName String @map("normalized_name")

  // "vendor" = pays them | "client" = pays us | "both" = appears on both sides
  type String @default("vendor")

  // Contact (foundation for future invoicing)
  email String?
  phone String?
  website String?
  taxId String? @map("tax_id") // NIF / CIF

  // Visual
  logoUrl String? @map("logo_url")

  // Intelligence defaults
  defaultCategoryId String? @map("default_category_id")
  defaultEntryType  String? @map("default_entry_type") // fixed | variable
  isAutoDetected    Boolean  @default(false) @map("is_auto_detected")
  detectionPatterns String[] @map("detection_patterns")

  createdAt DateTime @default(now()) @map("created_at")

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultCategory Category?         @relation(fields: [defaultCategoryId], references: [id], onDelete: SetNull)
  entries         Entry[]
  recurringPatterns RecurringPattern[]
  dismissedPatterns DismissedPattern[]

  @@unique([organizationId, normalizedName])
  @@index([organizationId])
  @@index([normalizedName])
  @@map("counterparties")
}

// ============================================
// Categories - System + Custom
// ============================================

model Category {
  id             String  @id @default(cuid())
  organizationId String? @map("organization_id") // null for system categories
  name           String
  slug           String
  color          String  @default("#6366f1")
  isSystem       Boolean @default(false) @map("is_system")
  entryType      String? @map("entry_type") // fixed, variable, income, transfer
  createdAt      DateTime @default(now()) @map("created_at")

  organization      Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  counterparties    Counterparty[]
  entries           Entry[]
  recurringPatterns RecurringPattern[]
  preferences       CategoryPreference[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([isSystem])
  @@map("categories")
}

model CategoryPreference {
  organizationId String  @map("organization_id")
  categoryId     String  @map("category_id")
  isHidden       Boolean @default(false) @map("is_hidden")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([organizationId, categoryId])
  @@map("category_preferences")
}

// ============================================
// Recurring Patterns - Detected subscriptions
// ============================================

model RecurringPattern {
  id                 String    @id @default(cuid())
  organizationId     String    @map("organization_id")
  name               String
  counterpartyId     String?   @map("counterparty_id")
  frequency          String // weekly, biweekly, monthly, quarterly, yearly
  expectedAmount     Float?    @map("expected_amount")
  amountVariancePct  Float     @default(15) @map("amount_variance_pct")
  expectedDayOfMonth Int?      @map("expected_day_of_month")
  categoryId         String?   @map("category_id")
  entryType          String    @default("fixed") @map("entry_type") // fixed | variable
  direction          String    @default("expense") @map("direction") // expense | income
  isActive           Boolean   @default(true) @map("is_active")
  isConfirmed        Boolean   @default(false) @map("is_confirmed")
  confidenceScore    Float?    @map("confidence_score")
  firstOccurrence    DateTime? @map("first_occurrence")
  lastOccurrence     DateTime? @map("last_occurrence")
  occurrenceCount    Int       @default(0) @map("occurrence_count")
  pauseReason        String?   @map("pause_reason")
  pausedAt           DateTime? @map("paused_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  entries      Entry[]
  alerts       Alert[]

  @@index([organizationId])
  @@index([isActive])
  @@index([isConfirmed])
  @@map("recurring_patterns")
}

// ============================================
// Alerts - Smart notifications
// ============================================

model Alert {
  id                 String   @id @default(cuid())
  organizationId     String   @map("organization_id")
  type               String // low_balance, high_expense, missed_recurring, unusual_activity, runway_warning, high_income
  title              String
  message            String
  severity           String   @default("info") // info, warning, critical
  accountId          String?  @map("account_id")
  entryId            String?  @map("entry_id")
  recurringPatternId String?  @map("recurring_pattern_id")
  isRead             Boolean  @default(false) @map("is_read")
  isDismissed        Boolean  @default(false) @map("is_dismissed")
  metadata           Json?
  createdAt          DateTime @default(now()) @map("created_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account          Account?          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  entry            Entry?            @relation(fields: [entryId], references: [id], onDelete: Cascade)
  recurringPattern RecurringPattern? @relation(fields: [recurringPatternId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([isRead])
  @@index([isDismissed])
  @@index([type])
  @@map("alerts")
}

// ============================================
// Exports - Download history
// ============================================

model Export {
  id               String    @id @default(cuid())
  organizationId   String    @map("organization_id")
  name             String
  filePath         String    @map("file_path")
  fileSize         Int?      @map("file_size")
  startDate        DateTime  @map("start_date")
  endDate          DateTime  @map("end_date")
  entryCount       Int?      @map("entry_count")
  documentCount    Int?      @map("document_count")
  includesCsv      Boolean   @default(true) @map("includes_csv")
  includesPdf      Boolean   @default(true) @map("includes_pdf")
  includesDocuments Boolean  @default(true) @map("includes_documents")
  status           String    @default("pending") // pending, processing, completed, failed
  errorMessage     String?   @map("error_message")
  generatedByOrgId String?   @map("generated_by_org_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  completedAt      DateTime? @map("completed_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("exports")
}

// ============================================
// User Preferences
// ============================================

model UserPreference {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  theme       String   @default("system")
  locale      String   @default("en-US")
  compactMode Boolean  @default(false) @map("compact_mode")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

// ============================================
// Notification Settings
// ============================================

model NotificationSetting {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  emailAlerts          Boolean  @default(true) @map("email_alerts")
  emailWeeklyDigest    Boolean  @default(true) @map("email_weekly_digest")
  emailLowBalance      Boolean  @default(true) @map("email_low_balance")
  emailHighSpend       Boolean  @default(true) @map("email_high_spend")
  emailRunwayCritical  Boolean  @default(true) @map("email_runway_critical")
  emailUnusualActivity Boolean  @default(true) @map("email_unusual_activity")
  emailSyncErrors      Boolean  @default(true) @map("email_sync_errors")
  inAppAlerts          Boolean  @default(true) @map("in_app_alerts")
  lowBalanceThreshold  Float?   @map("low_balance_threshold")
  highExpenseThreshold Float?   @map("high_expense_threshold")
  runwayThreshold      Float?   @default(3) @map("runway_threshold")
  unusualMultiplier    Float?   @default(2) @map("unusual_multiplier")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

// ============================================
// Dismissed Patterns
// ============================================

model DismissedPattern {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  counterpartyId String?  @map("counterparty_id")
  patternName    String   @map("pattern_name")
  dismissedAt    DateTime @default(now()) @map("dismissed_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  counterparty Counterparty? @relation(fields: [counterpartyId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([counterpartyId])
  @@map("dismissed_patterns")
}

// ============================================
// Invitations
// ============================================

model Invitation {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  email          String
  role           String    @default("member")
  token          String    @unique
  status         String    @default("pending")
  expiresAt      DateTime  @map("expires_at")
  invitedById    String    @map("invited_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  acceptedAt     DateTime? @map("accepted_at")

  clientName    String?   @map("client_name")

  emailStatus   String?   @map("email_status")
  emailSentAt   DateTime? @map("email_sent_at")
  emailError    String?   @map("email_error")
  resendEmailId String?   @map("resend_email_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
  @@index([email])
  @@index([status])
  @@map("invitations")
}

// ============================================
// Partner ↔ Client
// ============================================

model PartnerClient {
  id          String    @id @default(cuid())
  partnerId   String    @map("partner_id")
  clientId    String    @map("client_id")
  status      String    @default("pending")
  invitedAt   DateTime  @default(now()) @map("invited_at")
  connectedAt DateTime? @map("connected_at")

  partner Organization @relation("AsPartner", fields: [partnerId], references: [id], onDelete: Cascade)
  client  Organization @relation("AsClient", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([partnerId, clientId])
  @@index([partnerId])
  @@index([clientId])
  @@map("partner_clients")
}

// ============================================
// Inbox - Received documents
// ============================================

model InboxItem {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")

  fileName    String  @map("file_name")
  filePath    String  @map("file_path")
  contentType String? @map("content_type")
  size        Int?

  displayName String?  @map("display_name")
  amount      Decimal? @db.Decimal(12, 2)
  currency    String   @default("EUR")
  date        DateTime?
  cif         String?
  taxAmount   Decimal? @db.Decimal(12, 2) @map("tax_amount")
  taxRate     Float?   @map("tax_rate")

  status String @default("new")
  source String @default("upload")

  waMessageId String? @unique @map("wa_message_id")
  waSenderId  String? @map("wa_sender_id")

  tgMessageId String? @unique @map("tg_message_id")
  tgChatId    String? @map("tg_chat_id")

  meta Json?

  transactionId String? @map("transaction_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction      Transaction?            @relation(fields: [transactionId], references: [id])
  matchSuggestions MatchSuggestion[]
  attachments      TransactionAttachment[]

  @@index([organizationId])
  @@index([status])
  @@index([transactionId])
  @@map("inbox")
}

// ============================================
// Match Suggestions
// ============================================

model MatchSuggestion {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  transactionId  String @map("transaction_id")
  inboxItemId    String @map("inbox_item_id")

  confidenceScore Float @map("confidence_score")
  amountScore     Float @map("amount_score")
  dateScore       Float @map("date_score")
  nameScore       Float @map("name_score")
  currencyScore   Float @map("currency_score")

  matchType    String  @map("match_type")
  matchDetails Json?   @map("match_details")

  status       String    @default("pending")
  userActionAt DateTime? @map("user_action_at")
  userActionBy String?   @map("user_action_by")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction  Transaction  @relation(fields: [transactionId], references: [id])
  inboxItem    InboxItem    @relation(fields: [inboxItemId], references: [id])

  @@unique([transactionId, inboxItemId])
  @@index([organizationId])
  @@index([status])
  @@map("match_suggestions")
}

// ============================================
// Transaction Documents - File attachments
// ============================================

model TransactionDocument {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  transactionId  String @map("transaction_id")
  fileName       String @map("file_name")
  filePath       String @map("file_path")
  fileSize       Int?   @map("file_size")
  mimeType       String? @map("mime_type")
  invoiceNumber  String? @map("invoice_number")
  invoiceDate    DateTime? @map("invoice_date")
  vendorTaxId    String? @map("vendor_tax_id")
  totalAmount    Float?  @map("total_amount")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction  Transaction  @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([transactionId])
  @@map("transaction_documents")
}

// ============================================
// Agent Link Codes
// ============================================

model AgentLinkCode {
  id             String    @id @default(cuid())
  code           String    @unique
  organizationId String    @map("organization_id")
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expiresAt])
  @@map("agent_link_codes")
}

// ============================================
// Transaction Attachments - Confirmed receipt links
// ============================================

model TransactionAttachment {
  id            String   @id @default(cuid())
  transactionId String   @map("transaction_id")
  inboxItemId   String   @map("inbox_item_id")
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  inboxItem   InboxItem   @relation(fields: [inboxItemId], references: [id])

  @@unique([transactionId, inboxItemId])
  @@map("transaction_attachments")
}

// ============================================
// Proactive Messages
// ============================================

model ProactiveMessage {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  channel        String
  messageType    String   @map("message_type")
  content        String
  context        Json?
  sentAt         DateTime @default(now()) @map("sent_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, messageType, sentAt])
  @@map("proactive_messages")
}

