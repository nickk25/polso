// Prisma schema for Polso - Financial Management Platform
// Database: Neon PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// Multi-tenant Organization
// ============================================

model Organization {
  id              String   @id @default(cuid())
  name            String
  type            String   @default("client") // "partner" | "client"
  currency        String   @default("EUR")
  timezone        String   @default("Europe/Madrid")
  fiscalYearStart Int      @default(1) @map("fiscal_year_start")
  dateFormat      String   @default("MM/dd/yyyy") @map("date_format")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Subscription
  planType        String    @default("starter") @map("plan_type")
  planInterval    String?   @map("plan_interval") // "monthly" | "annual"
  planStartedAt   DateTime? @map("plan_started_at")
  planExpiresAt   DateTime? @map("plan_expires_at")
  trialEndsAt     DateTime? @map("trial_ends_at")

  // Creem billing
  creemCustomerId     String? @map("creem_customer_id")
  creemSubscriptionId String? @map("creem_subscription_id")

  // Agent channels
  whatsappPhone  String? @unique @map("whatsapp_phone")
  telegramChatId String? @unique @map("telegram_chat_id")
  agentOptOut    Boolean @default(false) @map("agent_opt_out")

  // Export preferences
  csvSeparator   String? @default(";") @map("csv_separator")

  // Scheduled plan changes (for downgrades)
  scheduledPlanType     String?   @map("scheduled_plan_type")
  scheduledPlanInterval String?   @map("scheduled_plan_interval")
  scheduledChangeAt     DateTime? @map("scheduled_change_at")

  // Relations
  userOrganizations UserOrganization[]
  accounts              Account[]
  pendingRequisitions   PendingRequisition[]
  transactions          Transaction[]
  categories        Category[]
  vendors           Vendor[]
  clients           Client[]
  expenses          Expense[]
  incomes           Income[]
  expenseInvoices   ExpenseInvoice[]
  recurringPatterns RecurringPattern[]
  dismissedPatterns DismissedPattern[]
  alerts            Alert[]
  exports               Export[]
  invitations           Invitation[]
  categoryPreferences   CategoryPreference[]
  inboxItems            InboxItem[]
  matchSuggestions      MatchSuggestion[]

  // Agent channel link codes
  agentLinkCodes AgentLinkCode[]

  // Proactive messages sent by the agent
  proactiveMessages ProactiveMessage[]

  // Partner ↔ Client links
  partnerLinks  PartnerClient[] @relation("AsClient")
  clientLinks   PartnerClient[] @relation("AsPartner")

  @@map("organizations")
}

model UserOrganization {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  organizationId String   @map("organization_id")
  role           String   @default("member")
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([userId])
  @@map("user_organizations")
}

// ============================================
// Banking - Connected Bank Accounts
// ============================================

model Account {
  id                   String    @id @default(cuid())
  organizationId       String    @map("organization_id")
  requisitionId        String?   @map("requisition_id")        // GoCardless requisition ID — groups all accounts from one bank connection
  institutionId        String?   @map("institution_id")        // GoCardless institution ID
  requisitionExpiresAt DateTime? @map("requisition_expires_at") // When the end-user agreement expires
  externalAccountId    String?   @map("external_account_id")   // GoCardless account UUID
  iban                 String?                                  // Account IBAN
  bic                  String?                                  // Bank BIC/SWIFT
  name                 String
  mask                 String?   // last 4 digits of IBAN
  officialName         String?   @map("official_name")
  accountType          String?   @map("account_type")          // depository, credit, loan
  accountSubtype       String?   @map("account_subtype")
  currency             String    @default("EUR")
  institutionName      String?   @map("institution_name")
  institutionLogo      String?   @map("institution_logo")
  status               String    @default("pending")           // pending, active, expired, disconnected
  lastSyncedAt         DateTime? @map("last_synced_at")
  syncError            String?   @map("sync_error")
  syncErrorRetries     Int       @default(0) @map("sync_error_retries")
  balanceAvailable     Float?    @map("balance_available")
  balanceCurrent       Float?    @map("balance_current")
  balanceLimit         Float?    @map("balance_limit")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  alerts       Alert[]

  @@index([organizationId])
  @@index([status])
  @@index([requisitionId])
  @@map("accounts")
}

// Temporary storage for a GoCardless requisition before the user completes OAuth.
// Cleaned up after the callback creates Account records.
model PendingRequisition {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  requisitionId  String   @map("requisition_id")
  institutionId  String   @map("institution_id")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("pending_requisitions")
}

// ============================================
// Transactions - Raw bank transactions
// ============================================

model Transaction {
  id                    String    @id @default(cuid())
  organizationId        String    @map("organization_id")
  accountId             String    @map("account_id")
  externalTransactionId String?   @map("external_transaction_id") // provider's transaction ID
  amount                Float
  currency              String    @default("EUR")
  date                  DateTime  // primary booked date
  authorizedDate        DateTime? @map("authorized_date")
  name                  String?   // raw transaction name from bank
  merchantName          String?   @map("merchant_name") // cleaned merchant name
  pending               Boolean   @default(false)
  paymentChannel        String?   @map("payment_channel") // online, in store, other
  transactionType       String?   @map("transaction_type") // debit, credit
  category              String?   // provider's primary category
  categoryDetailed      String?   @map("category_detailed") // provider's detailed category
  counterpartyName      String?   @map("counterparty_name") // normalized for matching
  createdAt             DateTime  @default(now()) @map("created_at")

  // Relations
  organization         Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account              Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expense              Expense?
  income               Income?
  inboxItems           InboxItem[]
  matchSuggestions     MatchSuggestion[]
  transactionAttachments TransactionAttachment[]

  @@unique([accountId, externalTransactionId])
  @@unique([organizationId, externalTransactionId]) // Prevent duplicates when relinking bank
  @@index([organizationId])
  @@index([accountId])
  @@index([date])
  @@index([counterpartyName])
  @@map("transactions")
}

// ============================================
// Categories - System + Custom
// ============================================

model Category {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id") // null for system categories
  name           String
  slug           String
  color          String   @default("#6366f1")
  icon           String?
  parentId       String?  @map("parent_id")
  isSystem       Boolean  @default(false) @map("is_system")
  expenseType    String?  @map("expense_type") // fixed, variable, income, transfer
  createdAt      DateTime @default(now()) @map("created_at")

  // Relations
  organization      Organization?        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent            Category?            @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children          Category[]           @relation("CategoryHierarchy")
  vendors           Vendor[]
  clientDefaults    Client[]             @relation("ClientDefaultCategory")
  expenses          Expense[]
  incomes           Income[]
  recurringPatterns RecurringPattern[]
  preferences       CategoryPreference[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([isSystem])
  @@map("categories")
}

model CategoryPreference {
  organizationId String @map("organization_id")
  categoryId     String @map("category_id")
  isHidden       Boolean @default(false) @map("is_hidden")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([organizationId, categoryId])
  @@map("category_preferences")
}

// ============================================
// Vendors - Suppliers/Merchants
// ============================================

model Vendor {
  id                 String   @id @default(cuid())
  organizationId     String   @map("organization_id")
  name               String
  normalizedName     String   @map("normalized_name")
  logoUrl            String?  @map("logo_url")
  website            String?
  taxId              String?  @map("tax_id")
  defaultCategoryId  String?  @map("default_category_id")
  defaultExpenseType String?  @map("default_expense_type") // fixed, variable
  isAutoDetected     Boolean  @default(false) @map("is_auto_detected")
  detectionPatterns  String[] @map("detection_patterns")
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultCategory   Category?          @relation(fields: [defaultCategoryId], references: [id], onDelete: SetNull)
  expenses          Expense[]
  recurringPatterns RecurringPattern[]
  dismissedPatterns DismissedPattern[]

  @@unique([organizationId, normalizedName])
  @@index([organizationId])
  @@index([normalizedName])
  @@map("vendors")
}

// ============================================
// Clients - Income sources / Payers
// ============================================

model Client {
  id                String   @id @default(cuid())
  organizationId    String   @map("organization_id")
  name              String
  normalizedName    String   @map("normalized_name")
  logoUrl           String?  @map("logo_url")
  website           String?
  taxId             String?  @map("tax_id")
  defaultCategoryId String?  @map("default_category_id")
  isAutoDetected    Boolean  @default(false) @map("is_auto_detected")
  detectionPatterns String[] @map("detection_patterns")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  defaultCategory Category?    @relation("ClientDefaultCategory", fields: [defaultCategoryId], references: [id], onDelete: SetNull)
  incomes         Income[]

  @@unique([organizationId, normalizedName])
  @@index([organizationId])
  @@index([normalizedName])
  @@map("clients")
}

// ============================================
// Expenses - Enriched transactions
// ============================================

model Expense {
  id                 String    @id @default(cuid())
  organizationId     String    @map("organization_id")
  transactionId      String?   @unique @map("transaction_id")
  amount             Float
  currency           String    @default("EUR")
  date               DateTime
  description        String?
  categoryId         String?   @map("category_id")
  vendorId           String?   @map("vendor_id")
  expenseType        String    @default("variable") @map("expense_type") // fixed, variable
  recurringPatternId String?   @map("recurring_pattern_id")
  status             String    @default("pending") // pending, documented, excluded
  isManual           Boolean   @default(false) @map("is_manual")
  notes              String?
  categorySource     String?   @map("category_source") // vendor, plaid, keyword, manual
  categoryConfidence Float?    @map("category_confidence") // 0-1 confidence score
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction      Transaction?       @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  category         Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  vendor           Vendor?            @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  recurringPattern RecurringPattern?  @relation(fields: [recurringPatternId], references: [id], onDelete: SetNull)
  invoices         ExpenseInvoice[]
  alerts           Alert[]

  @@index([organizationId])
  @@index([date])
  @@index([status])
  @@index([expenseType])
  @@index([categoryId])
  @@index([vendorId])
  @@map("expenses")
}

// ============================================
// Income - Incoming money
// ============================================

model Income {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  transactionId  String?   @unique @map("transaction_id")
  clientId       String?   @map("client_id")
  amount         Float     // Always positive (absolute value)
  currency       String    @default("USD")
  date           DateTime
  description    String?
  categoryId     String?   @map("category_id")
  source         String    @default("other") // salary, freelance, investment, refund, transfer, other
  isRecurring    Boolean   @default(false) @map("is_recurring")
  status         String    @default("pending") // pending, confirmed, excluded
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Relations
  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction  Transaction?  @relation(fields: [transactionId], references: [id], onDelete: SetNull)
  category     Category?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([date])
  @@index([status])
  @@index([source])
  @@index([clientId])
  @@map("incomes")
}

// ============================================
// Expense Invoices - File attachments
// ============================================

model ExpenseInvoice {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  expenseId      String    @map("expense_id")
  fileName       String    @map("file_name")
  filePath       String    @map("file_path") // R2 object key
  fileSize       Int?      @map("file_size")
  mimeType       String?   @map("mime_type")
  invoiceNumber  String?   @map("invoice_number")
  invoiceDate    DateTime? @map("invoice_date")
  vendorTaxId    String?   @map("vendor_tax_id")
  totalAmount    Float?    @map("total_amount")
  createdAt      DateTime  @default(now()) @map("created_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  expense      Expense      @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expenseId])
  @@map("expense_invoices")
}

// ============================================
// Recurring Patterns - Detected subscriptions
// ============================================

model RecurringPattern {
  id                 String    @id @default(cuid())
  organizationId     String    @map("organization_id")
  name               String
  vendorId           String?   @map("vendor_id")
  frequency          String // weekly, biweekly, monthly, quarterly, yearly
  expectedAmount     Float?    @map("expected_amount")
  amountVariancePct  Float     @default(15) @map("amount_variance_pct")
  expectedDayOfMonth Int?      @map("expected_day_of_month")
  categoryId         String?   @map("category_id")
  expenseType        String    @default("fixed") @map("expense_type")
  isActive           Boolean   @default(true) @map("is_active")
  isConfirmed        Boolean   @default(false) @map("is_confirmed")
  confidenceScore    Float?    @map("confidence_score")
  firstOccurrence    DateTime? @map("first_occurrence")
  lastOccurrence     DateTime? @map("last_occurrence")
  occurrenceCount    Int       @default(0) @map("occurrence_count")
  pauseReason        String?   @map("pause_reason") // "manual" | "missed_payment"
  pausedAt           DateTime? @map("paused_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  category     Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  expenses     Expense[]
  alerts       Alert[]

  @@index([organizationId])
  @@index([isActive])
  @@index([isConfirmed])
  @@map("recurring_patterns")
}

// ============================================
// Alerts - Smart notifications
// ============================================

model Alert {
  id                 String   @id @default(cuid())
  organizationId     String   @map("organization_id")
  type               String // low_balance, high_expense, missed_recurring, unusual_activity, runway_warning
  title              String
  message            String
  severity           String   @default("info") // info, warning, critical
  accountId          String?  @map("account_id")
  expenseId          String?  @map("expense_id")
  recurringPatternId String?  @map("recurring_pattern_id")
  isRead             Boolean  @default(false) @map("is_read")
  isDismissed        Boolean  @default(false) @map("is_dismissed")
  metadata           Json?
  createdAt          DateTime @default(now()) @map("created_at")

  // Relations
  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account          Account?          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  expense          Expense?          @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  recurringPattern RecurringPattern? @relation(fields: [recurringPatternId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([isRead])
  @@index([isDismissed])
  @@index([type])
  @@map("alerts")
}

// ============================================
// Exports - Download history
// ============================================

model Export {
  id              String    @id @default(cuid())
  organizationId  String    @map("organization_id")
  name            String
  filePath        String    @map("file_path") // R2 object key
  fileSize        Int?      @map("file_size")
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  expenseCount    Int?      @map("expense_count")
  invoiceCount    Int?      @map("invoice_count")
  includesCsv     Boolean   @default(true) @map("includes_csv")
  includesPdf     Boolean   @default(true) @map("includes_pdf")
  includesInvoices Boolean  @default(true) @map("includes_invoices")
  status          String    @default("pending") // pending, processing, completed, failed
  errorMessage    String?   @map("error_message")
  generatedByOrgId String?  @map("generated_by_org_id") // org that triggered the export (partner or client)
  createdAt       DateTime  @default(now()) @map("created_at")
  completedAt     DateTime? @map("completed_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([status])
  @@map("exports")
}

// ============================================
// User Preferences - Per-user settings
// ============================================

model UserPreference {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  theme       String   @default("system") // light, dark, system
  locale      String   @default("en-US")
  compactMode Boolean  @default(false) @map("compact_mode")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("user_preferences")
}

// ============================================
// Notification Settings - Per-user notification preferences
// ============================================

model NotificationSetting {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  emailAlerts          Boolean  @default(true) @map("email_alerts")
  emailWeeklyDigest    Boolean  @default(true) @map("email_weekly_digest")
  emailLowBalance      Boolean  @default(true) @map("email_low_balance")
  emailHighSpend       Boolean  @default(true) @map("email_high_spend")
  emailRunwayCritical  Boolean  @default(true) @map("email_runway_critical")
  emailUnusualActivity Boolean  @default(true) @map("email_unusual_activity")
  emailSyncErrors      Boolean  @default(true) @map("email_sync_errors")
  inAppAlerts          Boolean  @default(true) @map("in_app_alerts")
  lowBalanceThreshold  Float?   @map("low_balance_threshold")
  highExpenseThreshold Float?   @map("high_expense_threshold")
  runwayThreshold      Float?   @default(3)    @map("runway_threshold")
  unusualMultiplier    Float?   @default(2)    @map("unusual_multiplier")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@map("notification_settings")
}

// ============================================
// Dismissed Patterns - Prevent re-detection
// ============================================

model DismissedPattern {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  vendorId       String?  @map("vendor_id")
  patternName    String   @map("pattern_name")
  dismissedAt    DateTime @default(now()) @map("dismissed_at")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor       Vendor?      @relation(fields: [vendorId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([vendorId])
  @@map("dismissed_patterns")
}

// ============================================
// Invitations - Team member invitations
// ============================================

model Invitation {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  email          String
  role           String    @default("member")
  token          String    @unique
  status         String    @default("pending") // pending, accepted, revoked
  expiresAt      DateTime  @map("expires_at")
  invitedById    String    @map("invited_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  acceptedAt     DateTime? @map("accepted_at")

  // Email tracking
  emailStatus   String?   @map("email_status") // sent, delivered, bounced, failed
  emailSentAt   DateTime? @map("email_sent_at")
  emailError    String?   @map("email_error")
  resendEmailId String?   @map("resend_email_id")

  // Relations
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([token])
  @@index([email])
  @@index([status])
  @@map("invitations")
}

// ============================================
// Partner ↔ Client - Asesoría manages autónomos
// ============================================

model PartnerClient {
  id          String    @id @default(cuid())
  partnerId   String    @map("partner_id")
  clientId    String    @map("client_id")
  status      String    @default("pending") // "pending" | "active" | "disconnected"
  invitedAt   DateTime  @default(now()) @map("invited_at")
  connectedAt DateTime? @map("connected_at")

  partner Organization @relation("AsPartner", fields: [partnerId], references: [id], onDelete: Cascade)
  client  Organization @relation("AsClient", fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([partnerId, clientId])
  @@index([partnerId])
  @@index([clientId])
  @@map("partner_clients")
}

// ============================================
// Inbox - Received documents (receipts, invoices)
// ============================================

model InboxItem {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")

  // File
  fileName    String  @map("file_name")
  filePath    String  @map("file_path") // R2 object key
  contentType String? @map("content_type") // "application/pdf", "image/jpeg"
  size        Int?

  // OCR-extracted metadata
  displayName String?  @map("display_name") // vendor name
  amount      Decimal? @db.Decimal(12, 2)
  currency    String   @default("EUR")
  date        DateTime? // invoice date
  cif         String?   // Spanish vendor tax ID

  // Processing state
  status String @default("new") // "new" | "processing" | "analyzing" | "suggested_match" | "no_match" | "done" | "archived"
  source String @default("upload") // "upload" | "whatsapp" | "telegram" | "email"

  // WhatsApp metadata (only set when source = "whatsapp")
  waMessageId String? @unique @map("wa_message_id") // deduplicate incoming messages
  waSenderId  String? @map("wa_sender_id")          // phone number to reply to

  // Telegram metadata (only set when source = "telegram")
  tgMessageId String? @unique @map("tg_message_id") // "{chatId}_{messageId}" for dedup
  tgChatId    String? @map("tg_chat_id")             // chat ID to reply to

  // OCR raw output
  meta Json?

  // Confirmed match
  transactionId String? @map("transaction_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization     Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction      Transaction?            @relation(fields: [transactionId], references: [id])
  matchSuggestions MatchSuggestion[]
  attachments      TransactionAttachment[]

  @@index([organizationId])
  @@index([status])
  @@index([transactionId])
  @@map("inbox")
}

// ============================================
// Match Suggestions - AI-suggested receipt↔transaction links
// ============================================

model MatchSuggestion {
  id             String @id @default(cuid())
  organizationId String @map("organization_id")
  transactionId  String @map("transaction_id")
  inboxItemId    String @map("inbox_item_id")

  // Scores (0–1)
  confidenceScore Float @map("confidence_score")
  amountScore     Float @map("amount_score")    // 30% weight
  dateScore       Float @map("date_score")      // 15% weight
  nameScore       Float @map("name_score")      // 10% weight
  currencyScore   Float @map("currency_score")  // 5% weight

  matchType    String  @map("match_type") // "auto_matched" | "high_confidence" | "suggested"
  matchDetails Json?   @map("match_details")

  status       String    @default("pending") // "pending" | "confirmed" | "declined" | "expired" | "unmatched"
  userActionAt DateTime? @map("user_action_at")
  userActionBy String?   @map("user_action_by")

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction  Transaction  @relation(fields: [transactionId], references: [id])
  inboxItem    InboxItem    @relation(fields: [inboxItemId], references: [id])

  @@unique([transactionId, inboxItemId])
  @@index([organizationId])
  @@index([status])
  @@map("match_suggestions")
}

// ============================================
// Agent Link Codes - Temporary codes for connecting WhatsApp/Telegram
// ============================================

model AgentLinkCode {
  id             String    @id @default(cuid())
  code           String    @unique
  organizationId String    @map("organization_id")
  expiresAt      DateTime  @map("expires_at")
  usedAt         DateTime? @map("used_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([expiresAt])
  @@map("agent_link_codes")
}

// ============================================
// Transaction Attachments - Confirmed receipt links
// ============================================

model TransactionAttachment {
  id            String   @id @default(cuid())
  transactionId String   @map("transaction_id")
  inboxItemId   String   @map("inbox_item_id")
  createdAt     DateTime @default(now()) @map("created_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  inboxItem   InboxItem   @relation(fields: [inboxItemId], references: [id])

  @@unique([transactionId, inboxItemId])
  @@map("transaction_attachments")
}

// ============================================
// Proactive Messages - Agent-initiated outbound messages
// ============================================

model ProactiveMessage {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  channel        String   // "whatsapp" | "telegram"
  messageType    String   @map("message_type") // "receipt_reminder" | "weekly_summary" | "monthly_summary" | "anomaly_alert"
  content        String   // AI-generated message text that was sent
  context        Json?    // Financial context passed to AI (audit trail)
  sentAt         DateTime @default(now()) @map("sent_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, messageType, sentAt])
  @@map("proactive_messages")
}
