# Database - Neon PostgreSQL
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require

# Neon Auth
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth

# Cloudflare R2 Storage
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=polso

# GoCardless Bank Account Data - Open Banking
GOCARDLESS_SECRET_ID=your_gocardless_secret_id
GOCARDLESS_SECRET_KEY=your_gocardless_secret_key
GOCARDLESS_REDIRECT_URI=http://localhost:3000/api/gocardless/callback

# Cron Jobs
CRON_SECRET=your_cron_secret

# Resend - Email
RESEND_API_KEY=re_xxxxxxxxx
RESEND_WAITLIST_SEGMENT_ID=seg_xxxxxxxxx
EMAIL_FROM="Polso <hello@polso.app>"
EMAIL_FROM_FOUNDER="Nick <nick@polso.app>"

# Creem - Billing
CREEM_API_KEY=creem_test_53tJTUbxBUw200pJzeQiMY
CREEM_TEST_MODE=true
CREEM_STARTER_MONTHLY_PRODUCT_ID=prod_1ssAqL6DUOUZ6LOncC4CqH
CREEM_STARTER_ANNUAL_PRODUCT_ID=prod_5SVNexT2s2o3alVdUrLdBq
CREEM_BUSINESS_MONTHLY_PRODUCT_ID=prod_7fDirPgESNE2k41Rew2QnK
CREEM_BUSINESS_ANNUAL_PRODUCT_ID=prod_6EOVdIvhW2CcU12t5m7pCc
CREEM_WEBHOOK_SECRET=whsec_R9l1LiySDNh7UbTEfDtrp

# Upstash Redis - cache, sync locks, AI rate limiting
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Anthropic - separate keys per use case
ANTHROPIC_API_KEY_CHAT=sk-ant-xxx   # dashboard assistant + agent Q&A (Sonnet)
ANTHROPIC_API_KEY_OCR=sk-ant-xxx    # receipt OCR + proactive messages (Haiku)

# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=your_meta_system_user_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_botfather_token
TELEGRAM_WEBHOOK_SECRET_TOKEN=your_telegram_webhook_secret

# App (web dashboard — apps/web)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Partner dashboard URL — used in partner notification emails sent from apps/web
NEXT_PUBLIC_PARTNER_APP_URL=http://localhost:3001

# "true" to allow self-registration; omit/false for invite-only (default)
PUBLIC_SIGNUP_ENABLED=false
